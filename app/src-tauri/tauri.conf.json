{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rMoney",
  "version": "0.38.0",
  "identifier": "com.rmoney.finance",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rMoney",
        "width": 430,
        "height": 850,
        "minWidth": 320,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: https:",
        "connect-src": "'self' https://open.er-api.com https://query1.finance.yahoo.com https://finance.yahoo.com https://api.polygon.io https://api.twelvedata.com https://www.alphavantage.co https://finnhub.io https://stooq.com https://api.coingecko.com https://api.anthropic.com https://api.openai.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "rMoney Data",
        "description": "rMoney backup file",
        "ext": ["rmy"]
      }
    ]
  }
}
