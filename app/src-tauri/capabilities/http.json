{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "http",
  "description": "Allows native HTTP requests for CORS-restricted market data providers (Yahoo Finance, Stooq)",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://query1.finance.yahoo.com/*" },
        { "url": "https://finance.yahoo.com/*" },
        { "url": "https://stooq.com/*" }
      ]
    }
  ]
}
